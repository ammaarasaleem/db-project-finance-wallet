          }
        },
        {
          "name": "4. Add Fixed Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Netflix\",\n  \"amount\": 15.00,\n  \"category\": \"Subscriptions\",\n  \"due_day\": 3\n}" },
            "url": { "raw": "{{base_url}}/finance/expenses", "host": ["{{base_url}}"], "path": ["finance","expenses"] }
          }
        },
        {
          "name": "5. Get My Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
