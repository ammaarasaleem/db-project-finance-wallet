            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 18.00,\n  \"is_active\": 1\n}" },
            "url": { "raw": "{{base_url}}/finance/expenses/1", "host": ["{{base_url}}"], "path": ["finance","expenses","1"] }
          }
        },
