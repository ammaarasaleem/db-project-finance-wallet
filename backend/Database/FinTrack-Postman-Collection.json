{
  "info": {
    "name": "FinTrack API — Complete Collection",
    "description": "FinTrack Finance Management System — All API endpoints with auto-token saving.\n\n📌 SETUP:\n1. Set base_url variable to http://localhost:5000/api\n2. Run 'Register' or 'Login' first — token saves automatically\n3. All other requests use {{token}} automatically\n\n👥 Test Users (after running SQLQuery_Enhanced.sql seed data):\n- Register fresh users via /auth/register for bcrypt-hashed passwords",
    "_postman_id": "fintrack-api-2024-v2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api", "type": "string", "description": "Base URL — change port if needed" },
    { "key": "token",    "value": "", "type": "string", "description": "JWT token — auto-filled after Login" },
    { "key": "user_id",  "value": "", "type": "string", "description": "Auto-filled after Login" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "description": "User registration, login, and profile management",
      "item": [
        {
          "name": "1. Register New User",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const res = pm.response.json();",
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => pm.expect(res.data).to.have.property('token'));",
            "if (res.data && res.data.token) {",
            "  pm.collectionVariables.set('token', res.data.token);",
            "  pm.collectionVariables.set('user_id', res.data.user_id);",
            "  console.log('✅ Token saved for:', res.data.username);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@email.com\",\n  \"password\": \"password123\",\n  \"phone\": \"555-9999\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] },
            "description": "Creates a new user account and auto-creates a wallet. Token is saved automatically."
          }
        },
        {
          "name": "2. Login",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const res = pm.response.json();",
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Login successful', () => pm.expect(res.success).to.be.true);",
            "if (res.data && res.data.token) {",
            "  pm.collectionVariables.set('token', res.data.token);",
            "  pm.collectionVariables.set('user_id', res.data.user_id);",
            "  console.log('✅ Logged in as:', res.data.username);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"testuser@email.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] },
            "description": "Login and get JWT token. Token is automatically saved to collection variables."
          }
        },
        {
          "name": "3. Get My Profile",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has user data', () => pm.expect(pm.response.json().data).to.have.property('username'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth","me"] },
            "description": "Returns logged-in user profile with wallet balance."
          }
        },
        {
          "name": "4. Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"password123\",\n  \"new_password\": \"newpassword456\"\n}" },
            "url": { "raw": "{{base_url}}/auth/change-password", "host": ["{{base_url}}"], "path": ["auth","change-password"] }
          }
        }
      ]
    },
    {
