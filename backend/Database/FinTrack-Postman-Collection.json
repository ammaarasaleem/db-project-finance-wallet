    {
      "name": "📊 Finance (Salary & Expenses)",
      "description": "Fixed salary and expenses management, budget overview",
      "item": [
        {
          "name": "1. Get Financial Overview",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has salary info', () => pm.expect(pm.response.json().data).to.have.property('salary'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/finance/overview", "host": ["{{base_url}}"], "path": ["finance","overview"] },
