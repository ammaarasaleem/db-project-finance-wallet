        {
          "name": "4. Transfer Money",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Transfer successful', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"receiver_username\": \"alice\",\n  \"amount\": 50.00,\n  \"note\": \"Paying back for coffee\"\n}" },
            "url": { "raw": "{{base_url}}/wallet/transfer", "host": ["{{base_url}}"], "path": ["wallet","transfer"] }
          }
        },
        {
          "name": "5. Transaction History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/wallet/transactions?limit=10&offset=0",
              "host": ["{{base_url}}"], "path": ["wallet","transactions"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" },
                { "key": "type", "value": "transfer", "disabled": true, "description": "Filter: transfer | bill_split | loan | loan_repayment" }
              ]
            }
          }
        }
      ]
    },
